# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── JWT Authentication ─────────────────────────────────────────────────────
# Generate a secure random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=your-secret-key-here

# ─── MongoDB ────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=resume_insight

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=8000

# ─── CORS (Production) ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins in production
# Example: CORS_ALLOWED_ORIGINS=https://myapp.vercel.app,https://myapp.com
CORS_ALLOWED_ORIGINS=

# ─── Groq AI (AI Assistant feature) ─────────────────────────────────────────
# Get a free key at https://console.groq.com
# Leave blank to disable AI and fall back to the rule-based assistant
GROQ_API_KEY=your_groq_api_key_here
