# Copy this file to .env and fill in your own values
# cp .env.example .env

# ─── Groq AI ───────────────────────────────────────────────
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ─── JWT Authentication ─────────────────────────────────────
# Generate a secure random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ─── MongoDB ────────────────────────────────────────────────
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=resume_insight

# ─── CORS (Production) ──────────────────────────────────────
# Comma-separated list of allowed frontend origins in production
# Example: CORS_ALLOWED_ORIGINS=https://myapp.vercel.app,https://myapp.com
CORS_ALLOWED_ORIGINS=
